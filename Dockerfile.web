# Build Stage
FROM node:20-alpine AS builder
WORKDIR /app

COPY web-client/package.json web-client/package-lock.json* ./
RUN npm install

# We need to copy the source into the build context
COPY web-client/ ./
RUN npm run build

# Serve Stage
FROM nginx:alpine
# Copy the compiled static React build artifact from Vite into the Nginx server
COPY --from=builder /app/dist /usr/share/nginx/html

# Important: Nginx defaults to 80, Cloud Run exposes 8080 internally. We remap.
COPY web-client/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 8080
CMD ["nginx", "-g", "daemon off;"]
